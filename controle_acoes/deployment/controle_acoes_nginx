server {
    listen 80;
    server_name www.invest.casatemporadaceara.cloud;

    location / {
        include proxy_params;
        proxy_pass http://unix:/var/www/controle_acoes/controle_acoes/controle_acoes.sock;
        proxy_read_timeout 300;
        proxy_connect_timeout 300;
        proxy_send_timeout 300;
    }
